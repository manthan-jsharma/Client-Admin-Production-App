### ========================================
### CURRENTLY USING MOCK/PLACEHOLDER VALUES
### See INTEGRATION_GUIDE.md for setup
### ========================================

### CORE CONFIGURATION
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
NODE_ENV=development

### DATABASE (Currently Mock - See INTEGRATION_GUIDE.md for real DB)
DATABASE_URL=mock://in-memory
MONGODB_USER=admin
MONGODB_PASSWORD=password

### EMAIL SERVICE (Currently Mock)
# Options: mock, resend, ses
NEXT_PUBLIC_EMAIL_PROVIDER=mock
# When switching to RESEND:
RESEND_API_KEY=re_placeholder_key_here
# When switching to AWS SES:
AWS_REGION=us-east-1

### STORAGE SERVICE (Currently Mock)
# Options: mock, s3, vercel-blob
NEXT_PUBLIC_STORAGE_PROVIDER=mock
# When switching to S3:
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=placeholder_access_key
AWS_SECRET_ACCESS_KEY=placeholder_secret_key
# When switching to Vercel Blob:
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

### PAYMENT SERVICE (Currently Mock)
# Options: mock, stripe, paypal
NEXT_PUBLIC_PAYMENT_PROVIDER=mock
# When switching to STRIPE:
STRIPE_PUBLIC_KEY=pk_placeholder
STRIPE_SECRET_KEY=sk_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
# When switching to PAYPAL:
PAYPAL_CLIENT_ID=placeholder
PAYPAL_SECRET=placeholder

### AI SERVICE (Currently Mock)
# Options: mock, openai, anthropic
NEXT_PUBLIC_AI_PROVIDER=mock
# When switching to OPENAI:
OPENAI_API_KEY=sk_placeholder_key_here
OPENAI_MODEL=gpt-3.5-turbo
# When switching to ANTHROPIC:
ANTHROPIC_API_KEY=sk-ant-placeholder

### APPLICATION URLS
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

### FEATURE FLAGS
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_AI_SUPPORT=true
NEXT_PUBLIC_ERROR_TRACKING_ENABLED=false

### EMAIL CONFIGURATION
EMAIL_FROM=noreply@yourdomain.com
EMAIL_DOMAIN=yourdomain.com

### ERROR TRACKING (Optional)
# SENTRY_DSN=placeholder_sentry_dsn
# NEXT_PUBLIC_GA_ID=placeholder_ga_id

### LOGGING
LOG_LEVEL=info
DEBUG=false

### RATE LIMITING
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900000

### SESSION CONFIGURATION
SESSION_SECRET=placeholder_session_secret_change_in_production
SESSION_MAX_AGE=86400

### CORS CONFIGURATION
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
